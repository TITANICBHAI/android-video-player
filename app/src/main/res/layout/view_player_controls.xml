<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Gradient scrim - top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_top"
        android:layout_gravity="top" />

    <!-- Gradient scrim - bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_bottom"
        android:layout_gravity="bottom" />

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:layout_gravity="top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="8dp" />

        <Button
            android:id="@+id/btnSpeed"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="1x"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnPip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pip"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Picture in picture" />

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="More options" />

    </LinearLayout>

    <!-- CENTER CONTROLS -->
    <LinearLayout
        android:id="@+id/centerControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="center"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/btnSkipBackward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_replay_10"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Seek backward 10s" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:layout_marginHorizontal="16dp"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/btnSkipForward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_forward_10"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Seek forward 10s" />

    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp">

        <!-- Seek bar -->
        <com.localvideoplayer.ui.SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- Time + actions row -->
        <LinearLayout
            android:id="@+id/timeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:text="0:00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:text=" / " />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:text="0:00" />

            <ImageButton
                android:id="@+id/btnLock"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_lock_open"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Lock" />

            <ImageButton
                android:id="@+id/btnFullscreen"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_fullscreen"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Fullscreen" />

        </LinearLayout>

    </LinearLayout>

    <!-- VOLUME INDICATOR (right side) -->
    <LinearLayout
        android:id="@+id/volumeIndicator"
        android:layout_width="40dp"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_indicator"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_volume"
            android:tint="@color/white" />

        <ProgressBar
            android:id="@+id/volumeProgress"
            style="?android:attr/progressBarStyleVertical"
            android:layout_width="4dp"
            android:layout_height="80dp"
            android:layout_marginVertical="4dp"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/tvVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- BRIGHTNESS INDICATOR (left side) -->
    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="40dp"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_indicator"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_brightness"
            android:tint="@color/white" />

        <ProgressBar
            android:id="@+id/brightnessProgress"
            style="?android:attr/progressBarStyleVertical"
            android:layout_width="4dp"
            android:layout_height="80dp"
            android:layout_marginVertical="4dp"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/tvBrightness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="10sp" />

    </LinearLayout>

</merge>
